<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="25dp"/>
            <size
                android:height="50dp"
                android:width="50dp"/>
            <solid android:color="#1368fb"/>
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <corners android:radius="25dp"/>
            <size
                android:height="50dp"
                android:width="50dp"/>
            <solid android:color="#1368fb"/>
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="25dp"/>
            <size
                android:height="50dp"
                android:width="50dp"/>
            <solid android:color="#1368fb"/>
        </shape>
    </item>
</selector>
