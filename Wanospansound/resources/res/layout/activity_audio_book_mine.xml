<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="@dimen/list_tab_parent_width"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_like_chapter"
            android:background="@drawable/home_tab_item_bg_selector"
            android:paddingLeft="@dimen/ab_mine_tab_left"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:text="@string/like_chapter"
            android:splitMotionEvents="false"/>
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_follow"
            android:background="@drawable/home_tab_item_bg_selector"
            android:paddingLeft="@dimen/ab_mine_tab_left"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:layout_marginTop="@dimen/tab_icon_right"
            android:text="@string/audiobook_follow"
            android:splitMotionEvents="false"/>
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_played"
            android:background="@drawable/home_tab_item_bg_selector"
            android:paddingLeft="@dimen/ab_mine_tab_left"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:layout_marginTop="@dimen/tab_icon_right"
            android:text="@string/audiobook_played"
            android:splitMotionEvents="false"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
