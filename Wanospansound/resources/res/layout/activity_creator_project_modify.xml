<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/btn_back"
        android:paddingLeft="25dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/ic_back_bg"
            android:layout_width="82dp"
            android:layout_height="33dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back_str"
                android:drawableLeft="@drawable/back_ic"
                android:drawablePadding="6dp"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="70dp"
        android:paddingTop="27dp"
        android:paddingRight="70dp"
        android:paddingBottom="17dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingLeft="80dp"
            android:paddingRight="80dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/cover_bg"
                android:padding="17dp"
                android:layout_width="250dp"
                android:layout_height="223dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#00000000"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/iv_cover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_img_loading"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/btn_change_cover"
                    android:background="@drawable/tab_normal"
                    android:paddingLeft="33dp"
                    android:paddingTop="10dp"
                    android:paddingRight="33dp"
                    android:paddingBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="17dp">
                    <ImageView
                        android:paddingRight="8dp"
                        android:layout_width="26dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_change_cover"/>
                    <TextView
                        android:textSize="17sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/change_cover"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:paddingLeft="33dp"
                android:layout_width="0dp"
                android:layout_height="223dp"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_edit_name"
                    android:paddingBottom="33dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="17sp"
                        android:textColor="#99f1f4ff"
                        android:id="@+id/tv_project_name"
                        android:paddingRight="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/project_name"/>
                    <EditText
                        android:textSize="15sp"
                        android:textColor="#ffffffff"
                        android:textColorHint="#66ffffff"
                        android:gravity="center_vertical"
                        android:id="@+id/et_project_name"
                        android:background="@drawable/tab_normal"
                        android:paddingLeft="13dp"
                        android:paddingTop="5dp"
                        android:paddingRight="13dp"
                        android:paddingBottom="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:hint="@string/input_max_ten"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:maxLength="10"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_edit_des"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="17sp"
                        android:textColor="#99f1f4ff"
                        android:id="@+id/tv_project_des"
                        android:paddingRight="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="@string/project_des"/>
                    <EditText
                        android:textSize="15sp"
                        android:textColor="#ffffffff"
                        android:textColorHint="#66ffffff"
                        android:gravity="top"
                        android:id="@+id/et_project_des"
                        android:background="@drawable/tab_normal"
                        android:paddingLeft="13dp"
                        android:paddingTop="5dp"
                        android:paddingRight="13dp"
                        android:paddingBottom="5dp"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="@string/input_max_250"
                        android:maxLength="250"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="17sp"
                android:textColor="#99ffffff"
                android:gravity="center"
                android:paddingRight="17dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pulling_works"/>
            <ProgressBar
                android:id="@+id/progress_pull"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="7dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_pull"
                android:layout_weight="1"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
            <TextView
                android:textSize="17sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_progress_percentage"
                android:paddingLeft="17dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(0%)"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:background="#33ffffff"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="26.5dp"
            android:paddingTop="33dp"
            android:paddingRight="26.5dp"
            android:paddingBottom="33dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cover_img_list"
                android:paddingBottom="40dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="157dp"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_comfirm"
                android:background="@drawable/tab_normal"
                android:paddingLeft="33dp"
                android:paddingTop="10dp"
                android:paddingRight="33dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_comfirm"
                    android:paddingRight="8dp"
                    android:visibility="gone"
                    android:layout_width="28dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_pull"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/tv_comfirm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/comfirm"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
