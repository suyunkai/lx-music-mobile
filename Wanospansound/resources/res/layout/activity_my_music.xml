<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="@dimen/my_music_home_layout_padding_t"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_left"
        android:layout_width="@dimen/list_tab_parent_width"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_my_music"
            android:background="@drawable/home_tab_item_bg_selector"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:text="@string/music_single"
            android:splitMotionEvents="false"
            android:paddingStart="@dimen/search_result_tab_text_margin_start"/>
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_my_music_group"
            android:background="@drawable/home_tab_item_bg_selector"
            android:paddingLeft="@dimen/search_result_tab_text_margin_start"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:layout_marginTop="@dimen/search_result_tab_margin_top"
            android:text="@string/my_music_group"
            android:splitMotionEvents="false"/>
        <TextView
            android:textSize="@dimen/tab_text_size"
            android:textColor="@color/tab_text_color_selector"
            android:gravity="center_vertical"
            android:id="@+id/tab_my_music_history"
            android:background="@drawable/home_tab_item_bg_selector"
            android:paddingLeft="@dimen/search_result_tab_text_margin_start"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_tab_h"
            android:layout_marginTop="@dimen/search_result_tab_margin_top"
            android:text="@string/my_music_history"
            android:splitMotionEvents="false"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/layout_right"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="@dimen/search_result_list_margin_end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/ll_left"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
