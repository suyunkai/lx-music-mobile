<?xml version="1.0" encoding="utf-8"?>
<com.wanos.MaterialAutoRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/templete_refresh_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:overlay="false"
    app:wave_color="@color/ab_wave_color"
    app:wave_show="true">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/templete_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="120dp"
        android:layout_marginEnd="72dp"/>
</com.wanos.MaterialAutoRefreshLayout>
