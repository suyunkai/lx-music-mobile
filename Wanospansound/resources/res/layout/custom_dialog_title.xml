<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="144dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="@dimen/relax_dialog_space"
        android:src="@drawable/icon_relax_dialog_close"
        android:layout_marginStart="@dimen/relax_dialog_space"/>
    <com.wanos.media.widget.WanosTextView
        android:textSize="48sp"
        android:textColor="@color/relax_dialog_title_text_color"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/iv_title"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/relax_dialog_space"
        android:maxLines="1"
        android:layout_marginHorizontal="144dp"
        app:wanos_weight="500"/>
</FrameLayout>
