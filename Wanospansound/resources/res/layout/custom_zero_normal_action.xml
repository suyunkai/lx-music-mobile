<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_control_back"
        android:visibility="visible"
        android:layout_width="@dimen/title_bar_btn_size"
        android:layout_height="@dimen/title_bar_btn_size"
        android:src="@drawable/icon_back_personalize"
        android:layout_marginStart="@dimen/w_left"
        android:elevation="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/w_font_size_1"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_control_title"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/title_bar_btn_size"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/btn_control_back"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_control_back"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_vip_flag"
        android:layout_width="72dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_relax_vip"
        android:layout_marginStart="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_control_title"
        app:layout_constraintLeft_toRightOf="@+id/tv_control_title"
        app:layout_constraintTop_toTopOf="@+id/tv_control_title"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_setting"
        android:layout_width="@dimen/title_bar_btn_size"
        android:layout_height="@dimen/title_bar_btn_size"
        android:src="@drawable/icon_relax_setting"
        android:layout_marginEnd="@dimen/w_left"
        app:layout_constraintBottom_toBottomOf="@+id/btn_control_back"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_control_back"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/baseline_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
    <com.wanos.media.widget.WanosClockView
        android:id="@+id/clock_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/baseline_clock"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/baseline_clock"/>
    <View
        android:id="@+id/v_mask"
        android:background="#66000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="1dp"/>
    <com.wanos.media.widget.controller.WanosZeroControlTimeSelectView
        android:id="@+id/wanos_zero_time_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="@+id/baseline_clock"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/baseline_clock"/>
    <com.wanos.media.widget.RelaxInfoActionButton
        android:id="@+id/btn_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="360dp"
        android:elevation="2dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/baseline_clock"/>
    <com.wanos.media.widget.WanosTextView
        android:textSize="@dimen/w_font_size_4"
        android:textColor="@color/zero_countdown_time_color"
        android:id="@+id/tv_count_down_time"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="200dp"
        android:elevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_action"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:wanos_weight="400"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:id="@+id/btn_control_personalize"
        android:background="@drawable/btn_zero_bg"
        android:layout_width="wrap_content"
        android:layout_height="96dp"
        android:layout_marginTop="60dp"
        android:minWidth="358dp"
        android:elevation="0dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_action">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/relax_icon_edit_btn"/>
        <com.wanos.media.ui.widget.WanosTextView
            android:textSize="@dimen/relax_main_text_size"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/zero_normal_btn_pro"
            android:layout_marginStart="16dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center_vertical"
        android:id="@+id/btn_open_vip"
        android:background="@drawable/btn_zero_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:elevation="0dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_action">
        <com.wanos.media.widget.WanosTextView
            android:textSize="28sp"
            android:textColor="#f4982c"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="@string/relax_open_vip"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/icon_open_vip"
            android:layout_marginStart="16dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.constraintlayout.widget.ConstraintLayout>
