<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/audio_select_bg2"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_audio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:src="@drawable/track_add_audio"
        android:layout_marginStart="58dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/white"
        android:id="@+id/tv_audio_track"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="音频轨道"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@+id/iv_audio"
        app:layout_constraintTop_toTopOf="@+id/iv_audio"/>
    <TextView
        android:textSize="20sp"
        android:textColor="#b0b3b5"
        android:id="@+id/tv_audio_and_record"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="添加音频素材和录音"
        app:layout_constraintStart_toStartOf="@+id/iv_audio"
        app:layout_constraintTop_toBottomOf="@+id/tv_audio_track"/>
    <ImageView
        android:id="@+id/iv_midi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:src="@drawable/track_add_audio"
        android:layout_marginStart="58dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_audio_and_record"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/white"
        android:id="@+id/tv_instrument_track"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="乐器轨道"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@+id/iv_midi"
        app:layout_constraintTop_toBottomOf="@+id/tv_audio_and_record"/>
    <TextView
        android:textSize="20sp"
        android:textColor="#b0b3b5"
        android:id="@+id/tv_add_instrument_parts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="26dp"
        android:text="添加各种乐器演奏片段"
        android:layout_marginEnd="102dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/iv_midi"
        app:layout_constraintTop_toBottomOf="@+id/tv_instrument_track"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/white"
        android:id="@+id/tv_midi"
        android:background="@drawable/bg_midi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MIDI"
        android:layout_marginStart="10dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_instrument_track"
        app:layout_constraintStart_toEndOf="@+id/tv_instrument_track"
        app:layout_constraintTop_toTopOf="@+id/tv_instrument_track"/>
    <View
        android:id="@+id/view_instrument"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/view_midi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_midi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_instrument"/>
</androidx.constraintlayout.widget.ConstraintLayout>
