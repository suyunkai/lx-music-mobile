<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/cv_view"
        android:layout_width="800dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/p_dialog_bg"
        app:cardCornerRadius="@dimen/mormal_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/dialog_padding_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/p_login_back"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="40sp"
                    android:textColor="@color/text_color"
                    android:gravity="center"
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="分享码"
                    android:textFontWeight="500"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="66dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_0"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:text=""
                        android:textFontWeight="500"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_1"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/creator_share_text_distance"
                        android:text=""
                        android:textFontWeight="500"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_2"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/creator_share_text_distance"
                        android:text=""
                        android:textFontWeight="500"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_3"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/creator_share_text_distance"
                        android:text=""
                        android:textFontWeight="500"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_4"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/creator_share_text_distance"
                        android:text=""
                        android:textFontWeight="500"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_color"
                        android:gravity="center"
                        android:id="@+id/code_5"
                        android:background="@drawable/share_text_bg"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/creator_share_text_distance"
                        android:text=""
                        android:textFontWeight="500"/>
                </LinearLayout>
                <EditText
                    android:textSize="34sp"
                    android:textColor="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:id="@+id/et_code"
                    android:background="@android:color/transparent"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:cursorVisible="false"
                    android:maxLength="6"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"/>
            </FrameLayout>
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@+id/layout_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp">
                <TextView
                    android:textSize="34sp"
                    android:textColor="@color/creator_share_tip"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="* 您可通过手机拍照将此分享码"/>
                <TextView
                    android:textSize="34sp"
                    android:textColor="@color/creator_share_tip"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发送给您的朋友哦！"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/layout_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp">
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_dialog_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/dialog_left_btn_bg_color"
                    app:cardCornerRadius="@dimen/mormal_radius"
                    app:cardElevation="0dp">
                    <TextView
                        android:textSize="34sp"
                        android:textColor="@color/dialog_left_btn_text_color"
                        android:gravity="center"
                        android:id="@+id/tv_dialog_left"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:layout_width="320dp"
                        android:layout_height="wrap_content"
                        android:text="保存"/>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_dialog_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dialog_widget_distance"
                    app:cardBackgroundColor="@color/dialog_share_right_btn_bg_color"
                    app:cardCornerRadius="@dimen/mormal_radius"
                    app:cardElevation="0dp">
                    <TextView
                        android:textSize="34sp"
                        android:textColor="@color/dialog_share_right_btn_text_color"
                        android:gravity="center"
                        android:id="@+id/tv_dialog_right"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:layout_width="320dp"
                        android:layout_height="wrap_content"
                        android:text="取消"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
