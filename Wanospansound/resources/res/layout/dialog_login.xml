<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/card_view"
        android:layout_width="@dimen/p_login_w"
        android:layout_height="@dimen/p_login_h"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@color/p_dialog_bg"
        app:cardCornerRadius="@dimen/p_login_ra"
        app:cardElevation="0dp"
        app:contentPadding="0dp">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/ll_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/p_login_back_w_h_out"
                    android:layout_marginTop="@dimen/p_login_title_margin_top">
                    <TextView
                        android:textSize="@dimen/p_login_title_size"
                        android:textColor="@color/p_title_selected"
                        android:id="@+id/tv_scale_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/scale_code_login"
                        android:layout_marginEnd="@dimen/p_login_title_margin_in"/>
                    <FrameLayout
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/fl_we_chat_code"
                        android:background="@drawable/p_wechat_bg"
                        android:visibility="invisible"
                        android:layout_width="0.1dp"
                        android:layout_height="0.1dp"/>
                    <TextView
                        android:textSize="@dimen/p_login_title_size"
                        android:textColor="@color/p_title_unselected"
                        android:id="@+id/tv_phone_number_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_number_login"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="@dimen/p_login_back_w_h_out"
                    android:layout_height="@dimen/p_login_back_w_h_out"
                    android:layout_marginTop="@dimen/p_login_back_m_t_out"
                    android:src="@drawable/p_login_back"
                    android:layout_marginStart="@dimen/p_login_back_m_l_out"/>
            </FrameLayout>
            <FrameLayout
                android:layout_gravity="center_horizontal"
                android:id="@+id/fl_content_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <include
                    android:id="@+id/ll_agreement"
                    android:visibility="visible"
                    layout="@layout/include_login_dialog_agreement"/>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/ll_scale_code"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/p_login_wechat_margin_top">
                    <FrameLayout
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:layout_gravity="center_horizontal"
                            android:background="#00000000"
                            android:layout_width="@dimen/p_login_wechat_h_w"
                            android:layout_height="@dimen/p_login_wechat_h_w"
                            android:backgroundTint="#00000000"
                            app:cardBackgroundColor="#00000000"
                            app:cardCornerRadius="@dimen/music_home_top_card_radius"
                            app:cardElevation="0dp"
                            app:cardMaxElevation="0dp"
                            app:contentPadding="0dp">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/iv_we_chat_code"
                                android:layout_width="@dimen/p_login_wechat_h_w"
                                android:layout_height="@dimen/p_login_wechat_h_w"/>
                        </androidx.cardview.widget.CardView>
                        <View
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/iv_we_chat_code_load"
                            android:padding="@dimen/p_login_wechat_padding"
                            android:layout_width="@dimen/p_login_wechat_h_w"
                            android:layout_height="@dimen/p_login_wechat_h_w"/>
                    </FrameLayout>
                    <TextView
                        android:textSize="@dimen/p_login_wechat_text_size"
                        android:textColor="@color/p_wechat_text_color"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/p_login_wechat_text_margin_top"
                        android:text="@string/p_wechat_login_text1"/>
                    <TextView
                        android:textSize="@dimen/p_login_wechat_text_size"
                        android:textColor="@color/p_wechat_text_color"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/p_wechat_login_text2"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_phone_number"
                    android:paddingLeft="@dimen/p_login_input_padding_left"
                    android:paddingTop="@dimen/p_login_input_padding_top"
                    android:paddingRight="@dimen/p_login_input_padding_left"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:theme="@style/BlueCursorEditTextTheme"
                            android:textSize="@dimen/p_login_input_text_size"
                            android:textColor="@color/p_login_input_text_color"
                            android:textColorHint="@color/p_login_input_hint_text"
                            android:gravity="center_vertical"
                            android:id="@+id/et_phone_number"
                            android:background="@drawable/bg_phone_edit"
                            android:paddingLeft="@dimen/p_login_input_p_l"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/p_login_input_height"
                            android:hint="@string/p_login_input_phone_hint"
                            android:singleLine="true"
                            android:maxLength="11"
                            android:digits="0123456789"
                            android:inputType="number"/>
                        <FrameLayout
                            android:orientation="horizontal"
                            android:background="@drawable/bg_phone_edit"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/p_login_input_height"
                            android:layout_marginTop="@dimen/p_login_input_m_t">
                            <EditText
                                android:theme="@style/BlueCursorEditTextTheme"
                                android:textSize="@dimen/p_login_input_text_size"
                                android:textColor="@color/p_login_input_text_color"
                                android:textColorHint="@color/p_login_input_hint_text"
                                android:gravity="center_vertical"
                                android:id="@+id/et_sms_code"
                                android:background="@null"
                                android:paddingLeft="@dimen/p_login_input_p_l"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="@string/please_input_sms_code"
                                android:singleLine="true"
                                android:maxLength="4"
                                android:digits="0123456789"
                                android:inputType="number"/>
                            <TextView
                                android:textSize="@dimen/p_login_sms_size"
                                android:textColor="@color/p_login_get_sms_code"
                                android:layout_gravity="center"
                                android:id="@+id/bt_sms_code"
                                android:paddingRight="@dimen/p_login_get_sms_right"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/get_sms_code"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/p_login_bt_margin_top">
                        <TextView
                            android:textSize="@dimen/p_login_bt_text_size"
                            android:textColor="@color/p_login_bt_text_color"
                            android:gravity="center"
                            android:id="@+id/bt_login"
                            android:background="@drawable/bg_button_login"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/p_login_bt_height"
                            android:layout_marginRight="@dimen/p_login_bt_margin_right"
                            android:text="@string/login_s"
                            android:layout_weight="1"/>
                        <TextView
                            android:textSize="@dimen/p_login_bt_text_size"
                            android:textColor="@color/p_login_bt_text_color_cancel"
                            android:gravity="center"
                            android:id="@+id/bt_login_cancel"
                            android:background="@drawable/bg_button_login_cancel"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/p_login_bt_height"
                            android:text="@string/login_cancel"
                            android:layout_weight="1"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
