<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/view_win"
        android:background="@drawable/bg_dialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"/>
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/cv_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/p_dialog_bg"
        app:cardCornerRadius="@dimen/p_login_ra"
        app:cardElevation="0dp"
        app:contentPadding="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="@dimen/ab_speed_padding_h">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="@dimen/p_login_back_w_h_out"
                android:layout_height="@dimen/p_login_back_w_h_out"
                android:layout_marginTop="@dimen/ab_speed_top"
                android:src="@drawable/p_login_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/ab_dialog_title"
                android:textColor="@color/text_color"
                android:gravity="center"
                android:id="@+id/tv_audio_book_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ab_speed_title"
                android:textFontWeight="500"
                app:layout_constraintBottom_toBottomOf="@+id/btn_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@+id/btn_back"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_0"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginTop="@dimen/ab_speed_btn_top"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_back">
                <ImageView
                    android:id="@+id/iv_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_0"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_1"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginLeft="@dimen/ab_speed_btn_left"
                app:layout_constraintLeft_toRightOf="@+id/btn_0"
                app:layout_constraintTop_toTopOf="@+id/btn_0">
                <ImageView
                    android:id="@+id/iv_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_1"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_2"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginTop="@dimen/ab_speed_btn_top2"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_0">
                <ImageView
                    android:id="@+id/iv_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_2"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_3"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginLeft="@dimen/ab_speed_btn_left"
                app:layout_constraintLeft_toRightOf="@+id/btn_2"
                app:layout_constraintTop_toTopOf="@+id/btn_2">
                <ImageView
                    android:id="@+id/iv_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_3"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_4"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginTop="@dimen/ab_speed_btn_top2"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_2">
                <ImageView
                    android:id="@+id/iv_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_4"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_5"
                android:background="@drawable/ab_btn_speed"
                android:layout_width="@dimen/ab_speed_btn_w"
                android:layout_height="@dimen/ab_speed_btn_h"
                android:layout_marginLeft="@dimen/ab_speed_btn_left"
                app:layout_constraintLeft_toRightOf="@+id/btn_4"
                app:layout_constraintTop_toTopOf="@+id/btn_4">
                <ImageView
                    android:id="@+id/iv_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ab_speed_5"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
