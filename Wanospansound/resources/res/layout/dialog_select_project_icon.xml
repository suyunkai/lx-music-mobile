<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:id="@+id/dialog_win"
    android:background="@color/edit_dialog_bg_alpha"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="center"
        android:id="@+id/dialog_view"
        android:background="@drawable/pop_bottom_bg"
        android:layout_width="@dimen/edit_dialog_w"
        android:layout_height="@dimen/edit_si_h">
        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/edit_new_track_padding"
            android:src="@drawable/dialog_close"
            android:layout_marginStart="@dimen/edit_new_track_padding"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/edit_dialog_title_text"
            android:textColor="@color/edit_color_text"
            android:id="@+id/tv_title_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_select_icon"
            app:layout_constraintBottom_toBottomOf="@+id/btn_close"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btn_close"/>
        <FrameLayout
            android:id="@+id/view_list"
            android:layout_width="match_parent"
            android:layout_height="@dimen/edit_si_list_h"
            android:layout_marginTop="@dimen/edit_si_list_top"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_icon_list"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/edit_select_list_left"
                android:layout_marginRight="@dimen/edit_select_list_right"/>
            <include
                android:id="@+id/empty_view"
                android:visibility="gone"
                layout="@layout/empty_view_c"/>
        </FrameLayout>
        <TextView
            android:textSize="@dimen/edit_btn_font_size"
            android:textColor="@color/dialog_left_btn_text_color"
            android:gravity="center"
            android:id="@+id/btn_sure"
            android:background="@drawable/edit_btn_bg1"
            android:paddingTop="@dimen/edit_btn_padding_hor"
            android:paddingBottom="@dimen/edit_btn_padding_hor"
            android:layout_width="@dimen/edit_si_btn_w"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/edit_si_btn_top"
            android:text="@string/edit_sure"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/view_list"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
