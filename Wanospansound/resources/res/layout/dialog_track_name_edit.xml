<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/cv_view"
        android:layout_width="1136dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/p_dialog_bg"
        app:cardCornerRadius="@dimen/mormal_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/dialog_padding_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/p_login_back"/>
                <TextView
                    android:textSize="40sp"
                    android:textColor="@color/text_color"
                    android:gravity="center"
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="80dp"
                    android:text="编辑音轨名"
                    android:textFontWeight="500"/>
            </LinearLayout>
            <EditText
                android:textSize="34sp"
                android:textColor="@color/dialog_edit_text_color"
                android:textColorHint="@color/dialog_edit_text_hint_color"
                android:gravity="center_vertical"
                android:id="@+id/et_track_name"
                android:background="@drawable/tab_normal_theme"
                android:paddingLeft="36dp"
                android:paddingTop="19dp"
                android:paddingRight="36dp"
                android:paddingBottom="19dp"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="66dp"
                android:hint="@string/input_max_ten"
                android:maxLines="1"
                android:singleLine="true"
                android:maxLength="10"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp">
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_dialog_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/dialog_left_btn_bg_color"
                    app:cardCornerRadius="@dimen/mormal_radius"
                    app:cardElevation="0dp">
                    <TextView
                        android:textSize="34sp"
                        android:textColor="@color/dialog_left_btn_text_color"
                        android:gravity="center"
                        android:id="@+id/tv_dialog_left"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:layout_width="488dp"
                        android:layout_height="wrap_content"
                        android:text="保存"/>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_dialog_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dialog_widget_distance"
                    app:cardBackgroundColor="@color/dialog_right_btn_text_color"
                    app:cardCornerRadius="@dimen/mormal_radius"
                    app:cardElevation="0dp">
                    <TextView
                        android:textSize="34sp"
                        android:textColor="@color/p_login_bt_text_color_cancel"
                        android:gravity="center"
                        android:id="@+id/tv_dialog_right"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:layout_width="488dp"
                        android:layout_height="wrap_content"
                        android:text="取消"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
