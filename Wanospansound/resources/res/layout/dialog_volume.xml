<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialog_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_bg"
            android:layout_width="@dimen/zero_zero"
            android:layout_height="@dimen/zero_zero"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/v_blur_color"
            android:background="@color/dialog_sound_image_alpha"
            android:layout_width="@dimen/zero_zero"
            android:layout_height="@dimen/zero_zero"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btn_finish"
            android:layout_width="188dp"
            android:layout_height="92dp"
            android:layout_marginTop="@dimen/dialog_sound_btn_top"
            android:layout_marginBottom="90dp"
            android:src="@drawable/zero_icon_dialog_close"
            android:layout_marginStart="@dimen/dialog_sound_btn_start"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.wanos.media.widget.WanosTextView
            android:textSize="@dimen/w_font_size_bar"
            android:textColor="@color/color_volume_dialog_title"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="@dimen/w_image_btn_size"
            android:text="@string/volume_dialog_title"
            app:layout_constraintBottom_toBottomOf="@+id/btn_finish"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btn_finish"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_content"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/zero_zero"
            android:layout_marginTop="@dimen/size_volume_dialog_content_top"
            android:layout_marginBottom="@dimen/size_volume_dialog_content_bottom"
            android:layout_marginHorizontal="@dimen/w_left"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_finish"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
