<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/order_item_margin_b">
    <androidx.cardview.widget.CardView
        android:id="@+id/order_cd_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/order_item_h"
        app:cardBackgroundColor="@color/order_item_bg"
        app:cardCornerRadius="@dimen/order_item_cover_radius"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/order_cd_img_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/order_item_cover_margin_t_b"
        android:layout_marginBottom="@dimen/order_item_cover_margin_t_b"
        android:layout_marginStart="@dimen/order_item_cover_margin_l_r"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/order_item_cover_radius"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/order_cd_bg"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@+id/order_cd_bg">
        <ImageView
            android:id="@+id/order_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="@dimen/order_item_title_text_size"
        android:textColor="@color/card_text_color_selector"
        android:id="@+id/order_tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/time_text_padding"
        app:layout_constraintLeft_toRightOf="@+id/order_cd_img_bg"
        app:layout_constraintTop_toTopOf="@+id/order_cd_img_bg"/>
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/order_item_state_margin_l"
        app:layout_constraintBottom_toBottomOf="@+id/order_tv_title"
        app:layout_constraintLeft_toRightOf="@+id/order_tv_title"
        app:layout_constraintTop_toTopOf="@+id/order_tv_title">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/order_img_vip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ab_list_vip"/>
    </FrameLayout>
    <TextView
        android:textSize="@dimen/order_item_desc_text_size"
        android:textColor="@color/order_item_desc_color"
        android:gravity="center_vertical"
        android:id="@+id/order_tv_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/order_item_desc_margin_b"
        app:layout_constraintBottom_toBottomOf="@+id/order_cd_img_bg"
        app:layout_constraintLeft_toLeftOf="@+id/order_tv_title"
        app:layout_constraintLeft_toRightOf="@+id/order_cd_img_bg"/>
    <TextView
        android:textSize="@dimen/order_item_desc_text_size"
        android:textColor="@color/order_item_desc_color"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/order_tv_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/order_item_desc_margin_b"
        android:maxLines="1"
        android:maxEms="30"
        app:layout_constraintBottom_toBottomOf="@+id/order_cd_img_bg"
        app:layout_constraintLeft_toRightOf="@+id/order_tv_price"
        app:layout_constraintTop_toTopOf="@+id/order_tv_price"/>
    <TextView
        android:textSize="@dimen/order_item_desc_text_size"
        android:textColor="@color/order_item_desc_color"
        android:gravity="center_vertical"
        android:id="@+id/order_tv_behind"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/order_item_desc_margin_b"
        app:layout_constraintBottom_toBottomOf="@+id/order_cd_img_bg"
        app:layout_constraintLeft_toRightOf="@+id/order_tv_number"
        app:layout_constraintTop_toTopOf="@+id/order_tv_number"/>
</androidx.constraintlayout.widget.ConstraintLayout>
