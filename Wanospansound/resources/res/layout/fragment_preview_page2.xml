<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="460dp"
        android:layout_height="460dp"
        android:layout_marginTop="260dp"
        android:layout_marginStart="200dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/mormal_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_album"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <ImageView
            android:layout_gravity="end|bottom"
            android:id="@+id/iv_collect"
            android:visibility="invisible"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/creator_no_collect2"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="35sp"
        android:textColor="@color/white"
        android:id="@+id/tv_song_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="作品名称作品名称"
        android:layout_marginStart="81dp"
        app:layout_constraintStart_toEndOf="@+id/cardView"
        app:layout_constraintTop_toTopOf="@+id/cardView"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/white"
        android:id="@+id/tv_song_type"
        android:background="@drawable/bg_text_song_type"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="38dp"
        android:paddingHorizontal="25dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_song_name"
        app:layout_constraintStart_toEndOf="@+id/tv_song_name"
        app:layout_constraintTop_toTopOf="@+id/tv_song_name"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/white"
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="200dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tv_song_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_song_name"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/viewCard"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/cardView"
        app:layout_constraintStart_toStartOf="@+id/tv_song_name">
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/p_user_ava_d"
            app:layout_constraintBottom_toBottomOf="@+id/cardView"
            app:layout_constraintStart_toStartOf="@+id/tv_song_name"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="35sp"
        android:textColor="@color/white"
        android:id="@+id/tv_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="46dp"
        app:layout_constraintBottom_toBottomOf="@+id/viewCard"
        app:layout_constraintStart_toEndOf="@+id/viewCard"
        app:layout_constraintTop_toTopOf="@+id/viewCard"/>
    <TextView
        android:textSize="28sp"
        android:textColor="#1368fb"
        android:id="@+id/tv_create_another"
        android:background="@drawable/bg_create_another"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="创作同款"
        android:layout_marginEnd="200dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="25dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_nickname"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_nickname"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_play_preview"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="130dp"
        android:src="@drawable/preview_play2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_loading"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/preview_blue_loading"
        app:layout_constraintStart_toStartOf="@+id/btn_play_preview"
        app:layout_constraintTop_toTopOf="@+id/btn_play_preview"/>
    <com.wanos.careditproject.view.widget.PlayerPageSeekBar
        android:layout_gravity="center"
        android:id="@+id/seekbar_progress"
        android:background="@null"
        android:paddingTop="15dp"
        android:paddingBottom="15dp"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:max="1000"
        android:progress="0"
        android:progressDrawable="@drawable/progress_seekbar_total2"
        android:thumb="@drawable/seek_thumb"
        android:thumbOffset="0dp"
        android:layout_weight="1"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:min="0"
        android:layout_marginHorizontal="200dp"
        android:paddingHorizontal="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_play_preview"
        app:layout_constraintTop_toBottomOf="@+id/cardView"/>
    <TextView
        android:textSize="28sp"
        android:textColor="#99e6e6e6"
        android:id="@+id/text_play_time0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="00:00"
        app:layout_constraintStart_toStartOf="@+id/seekbar_progress"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_progress"/>
    <TextView
        android:textSize="28sp"
        android:textColor="#99e6e6e6"
        android:id="@+id/text_play_time"
        android:paddingRight="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="00:00"
        app:layout_constraintEnd_toEndOf="@+id/seekbar_progress"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_progress"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/view_loading"
        android:background="@color/editing_page_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:indeterminate="true"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/loading"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
