<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/search_label_layout_padding_left">
    <ScrollView
        android:orientation="vertical"
        android:id="@+id/search_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/search_label_title_size"
                android:textColor="@color/search_label_title_color"
                android:id="@+id/search_record_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/search_label_record_title_margin_top"
                android:text="@string/search_record_text"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <com.wanos.media.util.FlowLayout
                android:id="@+id/flowlayout_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/search_flow_view_margin_t_b"
                app:horizontalSpacing="@dimen/search_flow_view_margin_l_r"
                app:itemColor="@color/search_result_tab_text_selector"
                app:itemSize="@dimen/search_flow_text_size"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/search_record_text"
                app:textPaddingH="@dimen/search_flow_view_padding_h"
                app:textPaddingV="@dimen/search_flow_view_padding_v"
                app:verticalSpacing="@dimen/search_flow_view_margin_t_b"/>
            <TextView
                android:textSize="@dimen/search_label_title_size"
                android:textColor="@color/search_label_title_color"
                android:id="@+id/search_hot_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/search_label_hot_title_margin_top"
                android:text="@string/search_hot_word_text"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/flowlayout_record"/>
            <com.wanos.media.util.FlowLayout
                android:id="@+id/flowlayout_hot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/search_flow_view_margin_t_b"
                app:horizontalSpacing="@dimen/search_flow_view_margin_l_r"
                app:itemColor="@color/search_result_tab_text_selector"
                app:itemSize="@dimen/search_flow_text_size"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/search_hot_word"
                app:textPaddingH="@dimen/search_flow_view_padding_h"
                app:textPaddingV="@dimen/search_flow_view_padding_v"
                app:verticalSpacing="@dimen/search_flow_view_margin_t_b"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
