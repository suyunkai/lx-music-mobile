<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_result_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/search_result_layout_margin_t"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/ll_song"
            android:background="@drawable/home_tab_item_bg_selector"
            android:layout_width="@dimen/search_result_tab_w"
            android:layout_height="@dimen/search_result_tab_h"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="@dimen/tab_text_size"
                android:textStyle="bold"
                android:textColor="@color/tab_text_color_selector"
                android:id="@+id/tv_song_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_song_text"
                android:layout_marginStart="@dimen/search_result_tab_text_margin_start"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/ll_song_list"
            android:background="@drawable/home_tab_item_bg_selector"
            android:layout_width="@dimen/search_result_tab_w"
            android:layout_height="@dimen/search_result_tab_h"
            android:layout_marginTop="@dimen/search_result_tab_margin_top"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_song">
            <TextView
                android:textSize="@dimen/tab_text_size"
                android:textColor="@color/tab_text_color_selector"
                android:id="@+id/tv_song_list_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_song_list_text"
                android:layout_marginStart="@dimen/search_result_tab_text_margin_start"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/ll_audio_book"
            android:background="@drawable/home_tab_item_bg_selector"
            android:layout_width="@dimen/search_result_tab_w"
            android:layout_height="@dimen/search_result_tab_h"
            android:layout_marginTop="@dimen/search_result_tab_margin_top"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_song_list">
            <TextView
                android:textSize="@dimen/tab_text_size"
                android:textColor="@color/tab_text_color_selector"
                android:id="@+id/tv_audio_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_audio_book_text"
                android:layout_marginStart="@dimen/search_result_tab_text_margin_start"
                android:textFontWeight="500"/>
        </LinearLayout>
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/ll_song"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
