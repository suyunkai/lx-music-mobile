<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/view_item"
    android:paddingBottom="@dimen/home_top_card_left_right_magin"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/home_top_card_left_right_magin">
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_item_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="280:280"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <ImageView
            android:id="@+id/im_music_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <FrameLayout
            android:layout_gravity="bottom|left"
            android:id="@+id/btn_music_play"
            android:background="@drawable/group_card_play_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/music_top_play_padding">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/iv_music_play"
                android:layout_width="@dimen/group_list_play_wh"
                android:layout_height="@dimen/group_list_play_wh"
                android:src="@drawable/group_card_pause"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_music_play"
                android:visibility="gone"
                android:layout_width="@dimen/group_list_progressbar_wh"
                android:layout_height="@dimen/group_list_progressbar_wh"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"/>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="@dimen/music_group_text_color"
        android:textColor="@color/card_title_text_color_2"
        android:ellipsize="end"
        android:id="@+id/tv_music_name"
        android:paddingTop="@dimen/music_group_top_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        app:layout_constraintLeft_toLeftOf="@+id/cd_item_view"
        app:layout_constraintTop_toBottomOf="@+id/cd_item_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>
