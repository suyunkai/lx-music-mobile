<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/item_creator_home_card_item_0"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="48dp"
    app:cardBackgroundColor="@color/creator_templete_bg"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:contentPadding="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/project_content_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="20dp">
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_item"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_bg_color"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:contentPadding="0dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/iv_project_item"
                android:tag="binding_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <FrameLayout
                android:layout_gravity="center"
                android:id="@+id/btn_audio_book_play"
                android:background="@drawable/group_card_play_bg"
                android:layout_width="@dimen/rec_music_item_play_bg_w"
                android:layout_height="@dimen/rec_music_item_play_bg_w"
                android:layout_margin="@dimen/music_top_play_padding">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/play_state"
                    android:layout_width="@dimen/rec_music_item_play_btn_w"
                    android:layout_height="@dimen/rec_music_item_play_btn_w"
                    android:src="@drawable/group_card_pause"/>
                <ProgressBar
                    android:layout_gravity="center"
                    android:id="@+id/pb_audiobook_play"
                    android:visibility="gone"
                    android:layout_width="@dimen/rec_music_item_progress_w"
                    android:layout_height="@dimen/rec_music_item_progress_w"
                    android:indeterminate="true"
                    android:alpha="0.9"
                    android:indeterminateTint="#ffffff"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/play_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textSize="18sp"
                    android:textColor="#66ffffff"
                    android:layout_gravity="bottom|left"
                    android:id="@+id/tv_duration_0"
                    android:tag="binding_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/creator_templete_item_left"
                    android:layout_marginBottom="@dimen/creator_templete_item_bottom"
                    android:lineHeight="36dp"
                    android:textFontWeight="400"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#66ffffff"
                    android:layout_gravity="bottom|left"
                    android:id="@+id/tv_play_time"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/creator_templete_item_left"
                    android:layout_marginBottom="@dimen/creator_templete_item_bottom"
                    android:text="00:00"
                    android:lineHeight="36dp"
                    android:textFontWeight="400"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#66ffffff"
                    android:layout_gravity="bottom|right"
                    android:id="@+id/tv_duration_1"
                    android:tag="binding_3"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/creator_templete_item_left"
                    android:layout_marginBottom="@dimen/creator_templete_item_bottom"
                    android:lineHeight="36dp"
                    android:textFontWeight="400"/>
                <ProgressBar
                    android:layout_gravity="bottom"
                    android:id="@+id/seekbar_progress"
                    android:background="@null"
                    android:visibility="invisible"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="1000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_seekbar_templete"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:min="0"
                    android:layout_marginHorizontal="10dp"
                    android:paddingHorizontal="0dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:orientation="vertical"
            android:paddingTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="@+id/cv_item"
            app:layout_constraintTop_toBottomOf="@+id/cv_item">
            <TextView
                android:textSize="34sp"
                android:textColor="@color/text_color"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tv_project_name"
                android:tag="binding_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:paddingHorizontal="20dp"
                android:textFontWeight="500"/>
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">
                <TextView
                    android:textSize="28sp"
                    android:textColor="@color/creator_home_card_button_text_selector"
                    android:gravity="center"
                    android:id="@+id/tv_edit"
                    android:background="@drawable/creator_templete_edit_0_selector"
                    android:layout_width="158dp"
                    android:layout_height="70dp"
                    android:text="@string/create_home_item_create_same"
                    android:textFontWeight="400"/>
                <androidx.cardview.widget.CardView
                    android:id="@+id/layout_collect"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_marginStart="14dp"
                    app:cardBackgroundColor="@color/creator_home_tag_item_bg_normal"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/btn_collect"
                        android:tag="binding_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
