<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/item_creator_mine_work_0"
    android:paddingBottom="50dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_user"
        android:layout_width="match_parent"
        android:layout_height="96.8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/iv_user"
                android:tag="binding_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
        <TextView
            android:textSize="36sp"
            android:textColor="@color/text_color"
            android:id="@+id/tv_user_name"
            android:tag="binding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="33.6dp"
            app:layout_constraintStart_toEndOf="@+id/layout_avatar"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginStart="33.6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/layout_avatar">
            <TextView
                android:textSize="28sp"
                android:textColor="@color/creator_mine_work_time"
                android:id="@+id/tv_user_desc"
                android:tag="binding_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="24sp"
                android:textColor="@color/text_color"
                android:gravity="center"
                android:tag="binding_4"
                android:background="@drawable/bg_creator_mine_common_tag_bg"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="46dp"
                android:paddingHorizontal="25dp"/>
            <LinearLayout
                android:textSize="24sp"
                android:textColor="@color/text_color"
                android:gravity="center"
                android:orientation="horizontal"
                android:tag="binding_5"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="46dp"
                android:paddingHorizontal="25dp">
                <TextView
                    android:textSize="24sp"
                    android:gravity="center"
                    android:tag="binding_6"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="24sp"
                    android:textColor="@color/edit_color_main"
                    android:gravity="center"
                    android:tag="binding_7"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/create_mine_publish_status_audit_fail_more"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:tag="binding_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_creator_mine_work_card_more"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_work"
        android:tag="binding_9"
        android:background="@drawable/bg_creator_work_card_main"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_user">
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="25.6dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:tag="binding_10"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/layout_title"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="38dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/layout_image"
            app:layout_constraintTop_toTopOf="@+id/layout_image">
            <TextView
                android:textSize="36sp"
                android:textColor="@color/text_color"
                android:tag="binding_11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="28sp"
                android:textColor="@color/text_color"
                android:gravity="center"
                android:tag="binding_12"
                android:background="@drawable/bg_creator_mine_common_tag_bg"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="38dp"
                android:paddingHorizontal="25dp"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="28sp"
                android:textColor="@color/edit_color_main"
                android:gravity="center"
                android:tag="binding_13"
                android:background="@drawable/bg_item_creator_home_tag_item_normal"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/create_home_item_create_same"
                android:paddingHorizontal="16dp"/>
            <ImageView
                android:tag="binding_14"
                android:background="@drawable/bg_item_creator_home_tag_item_normal"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="60dp"/>
            <TextView
                android:textSize="28sp"
                android:textColor="@color/text_color"
                android:tag="binding_15"
                android:layout_width="71dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"/>
        </LinearLayout>
        <TextView
            android:textSize="28sp"
            android:ellipsize="end"
            android:tag="binding_16"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:maxLines="2"
            android:layout_marginHorizontal="38dp"
            app:layout_constraintBottom_toBottomOf="@+id/layout_image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/layout_image"
            app:layout_constraintTop_toBottomOf="@+id/layout_title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
