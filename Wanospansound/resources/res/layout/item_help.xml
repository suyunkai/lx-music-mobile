<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center_horizontal"
        android:layout_width="@dimen/relax_help_vp_item_width"
        android:layout_height="@dimen/relax_help_vp_item_height"
        app:cardCornerRadius="@dimen/w_radius"
        app:cardElevation="0dp">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>
    <com.wanos.media.widget.WanosTextView
        android:textSize="@dimen/relax_main_text_size"
        android:textColor="@color/w_font_title_2"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/relax_help_item_text_top"
        android:lines="3"
        android:paddingHorizontal="14dp"
        app:wanos_weight="500"/>
</androidx.appcompat.widget.LinearLayoutCompat>
