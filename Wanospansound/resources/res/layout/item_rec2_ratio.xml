<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <View
        android:background="@drawable/rec_audio_book_pages"
        android:layout_width="@dimen/rec_audiobook_item_pages_bg_w"
        android:layout_height="0dp"
        android:layout_marginStart="-32dp"
        app:layout_constraintBottom_toBottomOf="@+id/avatar"
        app:layout_constraintStart_toEndOf="@+id/avatar"
        app:layout_constraintTop_toTopOf="@+id/avatar"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/avatar"
        android:layout_width="235dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <include layout="@layout/layout_rec2_common_play"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="@dimen/rec_music_item_name_text_size"
        android:textColor="@color/text_color"
        android:ellipsize="end"
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="42dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/iv_album_state"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@+id/avatar"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/iv_album_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ab_album_end"
        android:layout_marginStart="@dimen/rec_audiobook_item_state_margin_left"
        app:layout_constraintBottom_toBottomOf="@+id/tv_name"
        app:layout_constraintEnd_toEndOf="@+id/tv_desc"
        app:layout_constraintStart_toEndOf="@+id/tv_name"
        app:layout_constraintTop_toTopOf="@+id/tv_name"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/rec_music_item_desc_text_color"
        android:ellipsize="end"
        android:id="@+id/tv_desc"
        android:layout_width="671dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/rec_audiobook_item_desc_margin_v"
        android:maxLines="2"
        app:layout_constraintBottom_toTopOf="@+id/tv_episodes"
        app:layout_constraintStart_toStartOf="@+id/tv_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_name"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/rec_music_item_desc_text_color"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@+id/tv_episodes"
        android:layout_width="476dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toTopOf="@+id/tv_episodes2"
        app:layout_constraintStart_toStartOf="@+id/tv_name"/>
    <TextView
        android:textSize="28sp"
        android:textColor="@color/rec_music_item_desc_text_color"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@+id/tv_episodes2"
        android:layout_width="476dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tv_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
