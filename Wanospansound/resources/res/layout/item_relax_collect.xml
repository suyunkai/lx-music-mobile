<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/ca_space_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="@dimen/relax_radius"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/im_space_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_vip"
            android:layout_width="@dimen/relax_home_normal_vip_w"
            android:layout_height="@dimen/relax_home_normal_vip_h"
            android:src="@drawable/icon_zero_vip"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="end"
            android:id="@+id/btn_space_op_more"
            android:layout_width="@dimen/relax_home_normal_more_icon_w"
            android:layout_height="@dimen/relax_home_normal_more_icon_h"
            android:src="@drawable/space_btn_op_more"/>
    </androidx.cardview.widget.CardView>
    <com.wanos.media.widget.WanosTextView
        android:textSize="@dimen/relax_home_normal_text_size"
        android:textColor="@color/relax_main_text_color"
        android:ellipsize="end"
        android:id="@+id/tv_space_name"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/relax_home_normal_text_top_space"
        android:maxLines="1"
        app:layout_constraintLeft_toLeftOf="@+id/ca_space_bg"
        app:layout_constraintRight_toRightOf="@+id/ca_space_bg"
        app:layout_constraintTop_toBottomOf="@+id/ca_space_bg"/>
    <com.wanos.media.ui.widget.WanosTextView
        android:textSize="@dimen/relax_sub_text_size"
        android:textColor="@color/relax_sub_text_color"
        android:ellipsize="end"
        android:id="@+id/tv_sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        app:layout_constrainedWidth="true"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintLeft_toLeftOf="@+id/tv_space_name"
        app:layout_constraintRight_toLeftOf="@+id/iv_icon_tag"
        app:layout_constraintTop_toBottomOf="@+id/tv_space_name"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_icon_tag"
        android:layout_width="@dimen/relax_icon_w"
        android:layout_height="@dimen/relax_icon_h"
        android:layout_marginStart="@dimen/relax_icon_space"
        app:layout_constraintBottom_toBottomOf="@+id/tv_sub_title"
        app:layout_constraintLeft_toRightOf="@+id/tv_sub_title"
        app:layout_constraintRight_toRightOf="@+id/ca_space_bg"
        app:layout_constraintTop_toTopOf="@+id/tv_sub_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
