<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/relax_home_merge"
    android:layout_marginEnd="@dimen/relax_home_space">
    <com.wanos.media.widget.SquareLinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/relax_item_add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/relax_image_button_size"
            android:layout_height="@dimen/relax_image_button_size"
            android:src="@drawable/icon_relax_add"/>
        <com.wanos.media.ui.widget.WanosTextView
            android:textSize="@dimen/relax_home_add_text_size"
            android:textColor="@color/relax_main_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_code_add"/>
    </com.wanos.media.widget.SquareLinearLayout>
</FrameLayout>
