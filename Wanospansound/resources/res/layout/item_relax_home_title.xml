<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/relax_home_title_space_vertical">
    <com.wanos.media.widget.WanosTextView
        android:textSize="@dimen/w_font_size_title"
        android:textColor="@color/w_font_title_1"
        android:gravity="center_vertical"
        android:id="@+id/tv_xq_space_group_more"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/relax_home_title_height"
        android:text="@string/xq_space_str"
        android:includeFontPadding="true"
        app:wanos_weight="500"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="@dimen/relax_home_title_icon_size"
        android:layout_height="@dimen/relax_home_title_icon_size"
        android:src="@drawable/ic_right_arrow"/>
</androidx.appcompat.widget.LinearLayoutCompat>
