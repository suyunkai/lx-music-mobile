<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="@dimen/search_result_music_group_item_margin_h"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/search_result_music_group_item_margin_h">
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_item_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/search_result_music_group_item_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="280:280"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <ImageView
            android:id="@+id/im_music_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@+id/btn_music_play"
            android:background="@drawable/group_card_play_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/search_result_music_group_item_btn_margin_l_b">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/iv_music_play"
                android:layout_width="@dimen/search_result_music_group_item_playing_wh"
                android:layout_height="@dimen/search_result_music_group_item_playing_wh"
                android:src="@drawable/group_card_pause"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_music_play"
                android:visibility="gone"
                android:layout_width="@dimen/search_result_music_group_item_pb_wh"
                android:layout_height="@dimen/search_result_music_group_item_pb_wh"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"/>
        </FrameLayout>
        <FrameLayout
            android:padding="@dimen/ab_album_item_vip_padding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_pay_state"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ab_list_vip"/>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="@dimen/search_result_audio_book_title_size"
        android:textColor="@color/search_result_audio_book_item_title_color"
        android:ellipsize="end"
        android:id="@+id/tv_audio_book_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/search_result_music_group_item_title_margin_t"
        android:maxLines="1"
        android:maxEms="8"
        app:layout_constraintLeft_toLeftOf="@+id/cd_item_view"
        app:layout_constraintTop_toBottomOf="@+id/cd_item_view"/>
    <ImageView
        android:id="@+id/iv_album_state"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/search_result_audio_book_item_state_margin_t"
        android:src="@drawable/ab_album_end"
        app:layout_constraintLeft_toLeftOf="@+id/tv_audio_book_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_audio_book_name"/>
    <TextView
        android:textSize="@dimen/search_result_audio_book_author_size"
        android:textColor="@color/search_result_audio_book_item_desc_color"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/tv_author_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="1"
        android:maxEms="6"
        android:layout_marginStart="@dimen/search_result_audio_book_item_author_margin_l"
        app:layout_constraintLeft_toRightOf="@+id/iv_album_state"
        app:layout_constraintTop_toTopOf="@+id/iv_album_state"/>
</androidx.constraintlayout.widget.ConstraintLayout>
