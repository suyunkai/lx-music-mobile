<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/ab_home_album_item_bottom"
    android:layout_marginEnd="@dimen/home_top_card_left_right_magin">
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_item_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <ImageView
            android:id="@+id/im_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <FrameLayout
            android:layout_gravity="bottom|left"
            android:id="@+id/btn_audio_book_play"
            android:background="@drawable/group_card_play_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/music_top_play_padding">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/iv_play_state"
                android:layout_width="@dimen/ab_album_item_play_size"
                android:layout_height="@dimen/ab_album_item_play_size"
                android:src="@drawable/group_card_pause"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_audiobook_play"
                android:visibility="gone"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"/>
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="top|left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_pay_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ab_list_vip"/>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="@dimen/ab_home_name_font_size"
        android:textColor="@color/text_color"
        android:ellipsize="end"
        android:id="@+id/tv_audio_book_name"
        android:paddingTop="@dimen/ab_item_name_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:lineHeight="@dimen/ab_item_name_h"
        app:layout_constraintLeft_toLeftOf="@+id/cd_item_view"
        app:layout_constraintTop_toBottomOf="@+id/cd_item_view"/>
    <ImageView
        android:id="@+id/iv_album_state"
        android:paddingRight="@dimen/ab_item_state_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ab_item_name_bottom"
        android:src="@drawable/ab_album_end"
        app:layout_constraintLeft_toLeftOf="@+id/cd_item_view"
        app:layout_constraintTop_toBottomOf="@+id/tv_audio_book_name"/>
    <TextView
        android:textSize="@dimen/ab_speaker_font_size"
        android:textColor="@color/ab_author_name_color"
        android:ellipsize="end"
        android:id="@+id/tv_audio_book_author_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@+id/iv_album_state"
        app:layout_constraintEnd_toEndOf="@+id/cd_item_view"
        app:layout_constraintStart_toEndOf="@+id/iv_album_state"
        app:layout_constraintTop_toTopOf="@+id/iv_album_state"/>
</androidx.constraintlayout.widget.ConstraintLayout>
