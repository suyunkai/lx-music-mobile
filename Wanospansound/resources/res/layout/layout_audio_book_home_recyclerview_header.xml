<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_top_one"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="608:320"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/cd_top_two"
        app:layout_constraintTop_toTopOf="parent">
        <com.wanos.media.ui.widget.banner.Banner
            android:id="@+id/ab_home_banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollIndicators="bottom"
            app:banner_auto_loop="true"
            app:banner_indicator_gravity="center"
            app:banner_indicator_height="@dimen/banner_indicator_height"
            app:banner_indicator_marginBottom="@dimen/banner_indicator_magin_bottom"
            app:banner_indicator_normal_color="@color/banner_indicator_normal_color"
            app:banner_indicator_normal_width="@dimen/banner_indicator_normal_width"
            app:banner_indicator_radius="@dimen/banner_indicator_radius"
            app:banner_indicator_selected_color="@color/banner_indicator_selected_color"
            app:banner_indicator_selected_width="@dimen/banner_indicator_selected_width"
            app:banner_indicator_space="12dp"
            app:banner_infinite_loop="true"
            app:banner_orientation="horizontal"
            app:banner_radius="@dimen/music_home_top_card_radius"/>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_top_two"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/home_top_card_left_right_magin"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="608:320"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/cd_top_one"
        app:layout_constraintRight_toLeftOf="@+id/cd_top_three"
        app:layout_constraintTop_toTopOf="@+id/cd_top_one">
        <ImageView
            android:id="@+id/iv_top_two"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/my_music_left_magin"
            android:layout_marginTop="@dimen/my_music_top_magin">
            <TextView
                android:textSize="@dimen/my_music_text_size"
                android:textColor="@color/white"
                android:id="@+id/tv_children"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/my_music_second_textsize"
                android:textColor="@color/white"
                android:id="@+id/tv_children_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ab_home_title_bottom"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_top_three"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/home_top_card_left_right_magin"
        android:layout_marginEnd="@dimen/music_list_item_decoration"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="608:320"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/cd_top_two"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cd_top_one">
        <ImageView
            android:id="@+id/iv_top_three"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/my_music_left_magin"
            android:layout_marginTop="@dimen/my_music_top_magin">
            <TextView
                android:textSize="@dimen/my_music_text_size"
                android:textColor="@color/white"
                android:id="@+id/tv_mine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/my_music_second_textsize"
                android:textColor="@color/white"
                android:id="@+id/tv_mine_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ab_home_title_bottom"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="cd_top_one,cd_top_two,cd_top_three"/>
    <TextView
        android:textSize="@dimen/card_title_textsize"
        android:textColor="@color/card_title_text_color"
        android:id="@+id/tv_album_all"
        android:paddingBottom="@dimen/music_group_list_margin_t"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/card_title_padding"
        android:text="@string/ab_home_all"
        android:drawablePadding="@dimen/drawable_padding"
        app:drawableRightCompat="@drawable/ic_right_arrow"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/barrier"/>
</androidx.constraintlayout.widget.ConstraintLayout>
