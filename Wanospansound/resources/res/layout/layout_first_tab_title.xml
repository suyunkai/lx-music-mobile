<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/material_first_tab_text_size"
        android:textColor="@drawable/material_tab_text_color_selector"
        android:gravity="center"
        android:id="@+id/tv_tab_title"
        android:background="@drawable/tab_item_bg_selector"
        android:paddingTop="@dimen/material_first_tab_text_padding_t_b"
        android:paddingBottom="@dimen/material_first_tab_text_padding_t_b"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/material_tab_text_padding_l_r"
        android:paddingEnd="@dimen/material_tab_text_padding_l_r"
        android:layout_marginEnd="@dimen/material_first_tab_margin_r"/>
</FrameLayout>
