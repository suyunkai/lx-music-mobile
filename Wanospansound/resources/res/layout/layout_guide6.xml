<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/view_blue_dot"
        android:background="@drawable/bg_blue_dot"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginTop="70dp"
        android:layout_marginStart="92dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/view_white_dot"
        android:background="@drawable/bg_white_dot"
        android:layout_width="28dp"
        android:layout_height="28dp"
        app:layout_constraintBottom_toBottomOf="@+id/view_blue_dot"
        app:layout_constraintEnd_toEndOf="@+id/view_blue_dot"
        app:layout_constraintStart_toStartOf="@+id/view_blue_dot"
        app:layout_constraintTop_toTopOf="@+id/view_blue_dot"/>
    <View
        android:background="#1368fb"
        android:layout_width="0dp"
        android:layout_height="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/view_white_dot"
        app:layout_constraintEnd_toEndOf="@+id/tv_content"
        app:layout_constraintStart_toEndOf="@+id/view_white_dot"
        app:layout_constraintTop_toTopOf="@+id/view_white_dot"/>
    <TextView
        android:textSize="52sp"
        android:textColor="@color/white"
        android:id="@+id/tv_guide_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="104dp"
        android:text="作品发布"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_blue_dot"/>
    <TextView
        android:textSize="32sp"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(6/6)"
        android:layout_marginStart="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_guide_title"
        app:layout_constraintStart_toEndOf="@+id/tv_guide_title"/>
    <TextView
        android:textSize="42sp"
        android:textColor="@color/white"
        android:id="@+id/tv_content"
        android:layout_width="824dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:text="作品项目支持实时保存，点击发布，即可将你的项目生成个人作品或同时发布社区。"
        app:layout_constraintStart_toStartOf="@+id/tv_guide_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_guide_title"/>
    <TextView
        android:textSize="36sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_skip"
        android:background="@drawable/bg_next_guide"
        android:layout_width="224dp"
        android:layout_height="88dp"
        android:layout_marginTop="109dp"
        android:layout_marginBottom="175dp"
        android:text="完成"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tv_guide_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_content"/>
</androidx.constraintlayout.widget.ConstraintLayout>
