<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/cd_item_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/w_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.wanos.media.ui.widget.ImageCardView
            android:id="@+id/im_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:cardSize="middle"/>
        <FrameLayout
            android:layout_gravity="bottom|left"
            android:id="@+id/btn_play"
            android:background="@drawable/group_card_play_bg"
            android:layout_width="@dimen/rec_music_item_play_bg_w"
            android:layout_height="@dimen/rec_music_item_play_bg_w"
            android:layout_marginLeft="@dimen/group_list_play_margin_l_b"
            android:layout_marginBottom="@dimen/group_list_play_margin_l_b">
            <com.airbnb.lottie.LottieAnimationView
                android:layout_gravity="center"
                android:id="@+id/iv_play_state"
                android:layout_width="@dimen/group_list_play_wh"
                android:layout_height="@dimen/group_list_play_wh"
                android:src="@drawable/group_card_pause"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/lottie_white"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_audiobook_play"
                android:visibility="gone"
                android:layout_width="@dimen/rec_music_item_progress_w"
                android:layout_height="@dimen/rec_music_item_progress_w"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"/>
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="top|left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/im_left_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ab_list_vip"/>
        </FrameLayout>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="top|right"
            android:id="@+id/btn_more"
            android:layout_width="@dimen/card_more_w"
            android:layout_height="@dimen/card_more_h"
            android:src="@drawable/card_btn_more"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="34sp"
        android:textColor="@color/w_font_title_1"
        android:ellipsize="end"
        android:id="@+id/tv_title"
        android:paddingTop="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintLeft_toLeftOf="@+id/cd_item_view"
        app:layout_constraintTop_toBottomOf="@+id/cd_item_view"/>
    <TextView
        android:textSize="@dimen/w_font_size_level_2"
        android:textColor="@color/w_font_title_2"
        android:ellipsize="end"
        android:id="@+id/tv_title_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/w_card_text1_top"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintLeft_toLeftOf="@+id/tv_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
