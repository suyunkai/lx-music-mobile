<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="136dp">
    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/bg_close"
        android:layout_marginStart="79dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="32sp"
        android:textColor="@color/white"
        android:id="@+id/tv_instrument_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="键盘"
        android:layout_marginStart="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintStart_toEndOf="@+id/iv_close"
        app:layout_constraintTop_toTopOf="@+id/iv_close"/>
    <TextView
        android:textSize="32sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_name"
        android:background="@drawable/bg_instrument"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="钢琴"
        android:layout_marginStart="50dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintStart_toEndOf="@+id/tv_instrument_name"
        app:layout_constraintTop_toTopOf="@+id/iv_close"/>
    <ImageView
        android:id="@+id/view_left_arrow"
        android:padding="9dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_left_arrow"
        app:layout_constraintBottom_toBottomOf="@+id/tv_name"
        app:layout_constraintStart_toStartOf="@+id/tv_name"
        app:layout_constraintTop_toTopOf="@+id/tv_name"/>
    <ImageView
        android:id="@+id/view_right_arrow"
        android:padding="9dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_right_arrow"
        app:layout_constraintBottom_toBottomOf="@+id/tv_name"
        app:layout_constraintEnd_toEndOf="@+id/tv_name"
        app:layout_constraintTop_toTopOf="@+id/tv_name"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_type"
        android:background="@drawable/bg_instrument"
        android:layout_width="370dp"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintStart_toEndOf="@+id/tv_name"
        app:layout_constraintTop_toTopOf="@+id/iv_close">
        <TextView
            android:textSize="32sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_instrument"
            android:background="@drawable/bg_purple"
            android:layout_width="134dp"
            android:layout_height="match_parent"
            android:text="乐器"
            app:layout_constraintBottom_toBottomOf="@+id/iv_close"
            app:layout_constraintStart_toEndOf="@+id/iv_close"
            app:layout_constraintTop_toTopOf="@+id/iv_close"/>
        <TextView
            android:textSize="32sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_midi_keyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="MIDI编辑器"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_instrument"
            app:layout_constraintTop_toTopOf="parent"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_keyboard_type"
        android:background="@drawable/bg_instrument"
        android:layout_width="400dp"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_close">
        <TextView
            android:textSize="32sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_fixed_keyboard"
            android:background="@drawable/bg_purple"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:text="固定键盘"
            app:layout_constraintBottom_toBottomOf="@+id/iv_close"
            app:layout_constraintStart_toEndOf="@+id/iv_close"
            app:layout_constraintTop_toTopOf="@+id/iv_close"/>
        <TextView
            android:textSize="32sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_slide_keyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="滑动键盘"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_instrument"
            app:layout_constraintTop_toTopOf="parent"/>
    </LinearLayout>
    <TextView
        android:textSize="32sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_value"
        android:background="@drawable/bg_instrument"
        android:layout_width="136dp"
        android:layout_height="60dp"
        android:text="量化"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_close"/>
    <TextView
        android:textSize="32sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_tweak"
        android:background="@drawable/bg_instrument"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="@string/quantization_4"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintEnd_toStartOf="@+id/tv_value"
        app:layout_constraintTop_toTopOf="@+id/iv_close"/>
    <ImageView
        android:id="@+id/view_left_arrow2"
        android:padding="9dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_left_arrow"
        app:layout_constraintBottom_toBottomOf="@+id/tv_tweak"
        app:layout_constraintStart_toStartOf="@+id/tv_tweak"
        app:layout_constraintTop_toTopOf="@+id/tv_tweak"/>
    <ImageView
        android:id="@+id/view_right_arrow2"
        android:padding="9dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_right_arrow"
        app:layout_constraintBottom_toBottomOf="@+id/tv_tweak"
        app:layout_constraintEnd_toEndOf="@+id/tv_tweak"
        app:layout_constraintTop_toTopOf="@+id/tv_tweak"/>
</androidx.constraintlayout.widget.ConstraintLayout>
