<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/ab_home_album_item_bottom"
    android:layout_marginEnd="@dimen/home_top_card_left_right_magin">
    <androidx.cardview.widget.CardView
        android:id="@+id/card_cover"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/music_home_top_card_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintDimensionRatio="35:49"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/im_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/im_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/iqy_cover_top_padding"
        app:layout_constraintRight_toRightOf="@+id/card_cover"
        app:layout_constraintTop_toTopOf="@+id/card_cover"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/iqy_movies_score_size"
        android:textColor="@color/iqy_ji"
        android:id="@+id/tv_ji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/iqy_cover_top_padding"
        android:lineHeight="@dimen/iqy_movies_score_h"
        app:layout_constraintBottom_toBottomOf="@+id/card_cover"
        app:layout_constraintRight_toRightOf="@+id/card_cover"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/ab_home_name_font_size"
        android:textColor="@color/text_color"
        android:ellipsize="end"
        android:id="@+id/tv_name"
        android:paddingTop="@dimen/ab_item_name_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:lineHeight="@dimen/ab_item_name_h"
        app:layout_constraintLeft_toLeftOf="@+id/card_cover"
        app:layout_constraintRight_toRightOf="@+id/card_cover"
        app:layout_constraintTop_toBottomOf="@+id/card_cover"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/ab_speaker_font_size"
        android:textColor="@color/ab_author_name_color"
        android:ellipsize="end"
        android:id="@+id/tv_name_ex"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/iqy_name_bottom"
        android:maxLines="1"
        app:layout_constraintLeft_toLeftOf="@+id/card_cover"
        app:layout_constraintRight_toRightOf="@+id/card_cover"
        app:layout_constraintTop_toBottomOf="@+id/tv_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
