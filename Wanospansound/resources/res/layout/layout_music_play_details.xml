<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/title_left_btn"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/title_bar_back_height"
        android:layout_marginTop="@dimen/title_bar_left_btn_right_padding"
        android:src="@drawable/icon_back"
        android:layout_marginStart="@dimen/title_bar_padding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/guideline"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.143"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/guideline_2"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.14"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/guideline_right_1"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.9"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/guideline_right_2"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.905"
        app:layout_constraintStart_toStartOf="parent"/>
    <FrameLayout
        android:id="@+id/fl_top_card"
        android:paddingRight="46dp"
        android:visibility="gone"
        android:layout_width="@dimen/music_play_cover_width"
        android:layout_height="@dimen/music_play_cover_height"
        android:layout_marginLeft="11dp"
        app:layout_constraintStart_toStartOf="@+id/guideline"
        app:layout_constraintTop_toTopOf="@+id/tv_music_name">
        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@+id/im_top_card"
            android:background="@color/card_bg_color"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:round="@dimen/music_home_top_card_radius"/>
    </FrameLayout>
    <androidx.constraintlayout.widget.Barrier
        android:orientation="horizontal"
        android:id="@+id/right_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="guideline,fl_top_card"/>
    <TextView
        android:textSize="@dimen/music_play_name_text_size"
        android:textColor="@color/card_text_color_selector"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/tv_music_name"
        android:paddingTop="14dp"
        android:layout_width="0dp"
        android:layout_height="@dimen/music_detail_name_height"
        android:layout_marginLeft="11dp"
        android:maxLines="1"
        android:textFontWeight="500"
        app:layout_constraintBottom_toTopOf="@+id/ll_singer"
        app:layout_constraintEnd_toStartOf="@+id/guideline_right_1"
        app:layout_constraintStart_toEndOf="@+id/right_barrier"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_singer"
        android:layout_width="0dp"
        android:layout_height="@dimen/music_detail_singer_height"
        android:layout_marginTop="@dimen/music_group_right_padding"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toTopOf="@+id/seekbar_music_progress"
        app:layout_constraintEnd_toEndOf="@+id/guideline_right_1"
        app:layout_constraintStart_toStartOf="@+id/tv_music_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_music_name">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_vip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/vip_magin_right"
                android:src="@drawable/ic_vip"/>
            <TextView
                android:textSize="@dimen/music_play_singer_text_size"
                android:textColor="@color/play_singer_name"
                android:ellipsize="end"
                android:id="@+id/tv_singer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
    <com.wanos.media.ui.widget.WanosSeekBar
        android:id="@+id/seekbar_music_progress"
        android:background="@null"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="0dp"
        android:layout_height="@dimen/music_seekbar_height"
        android:layout_marginTop="@dimen/music_seekbar_magin_top"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/progress_music_seekbar"
        android:thumb="@drawable/music_seek_thumb"
        android:thumbOffset="@dimen/muisc_seekbar_thumb_offset"
        android:layout_weight="1"
        android:layout_marginEnd="0dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_curr_time"
        app:layout_constraintEnd_toEndOf="@+id/guideline_right_2"
        app:layout_constraintStart_toStartOf="@+id/guideline_2"
        app:layout_constraintTop_toBottomOf="@+id/ll_singer"/>
    <TextView
        android:textSize="@dimen/seek_time_text_size"
        android:textColor="@color/seek_time_text_color"
        android:id="@+id/tv_curr_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="00:00"
        android:layout_marginStart="@dimen/muisc_seekbar_left_right_magin"
        app:layout_constraintBottom_toTopOf="@+id/ll_action"
        app:layout_constraintStart_toStartOf="@+id/guideline"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_music_progress"/>
    <TextView
        android:textSize="@dimen/seek_time_text_size"
        android:textColor="@color/seek_time_text_color"
        android:id="@+id/tv_dur_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:layout_marginEnd="11dp"
        app:layout_constraintEnd_toEndOf="@+id/guideline_right_1"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_music_progress"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_action"
        android:layout_width="0dp"
        android:layout_height="@dimen/music_play_control_bar_height"
        android:layout_marginTop="@dimen/music_play_control_bar_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/guideline_right_1"
        app:layout_constraintStart_toStartOf="@+id/guideline"
        app:layout_constraintTop_toBottomOf="@+id/tv_curr_time">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/iv_collect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_music_play_no_collect"
            android:scaleType="fitCenter"/>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/play_type"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/play_type_loop"
            android:scaleType="centerCrop"/>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/btn_last"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/play_last"
            android:scaleType="centerInside"/>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <FrameLayout
            android:id="@+id/btn_play"
            android:layout_width="120dp"
            android:layout_height="120dp">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/muisc_play_pause_bg"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/iv_play"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_music_play_pause"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/pb_music_play"
                android:visibility="gone"
                android:layout_width="@dimen/music_play_detail_progressbar_wh"
                android:layout_height="@dimen/music_play_detail_progressbar_wh"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"/>
        </FrameLayout>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/btn_next"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/play_next"
            android:scaleType="centerInside"/>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/play_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_music_play_list_normal"
            android:scaleType="centerInside"
            android:splitMotionEvents="false"/>
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/play_lrc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_music_play_lrc_selector"
            android:scaleType="centerInside"
            android:splitMotionEvents="false"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
