<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_rec2_header_daily"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_rec2_album_disk"
        android:layout_marginEnd="-99dp"
        app:layout_constraintBottom_toBottomOf="@+id/avatar"
        app:layout_constraintEnd_toEndOf="@+id/avatar"
        app:layout_constraintTop_toTopOf="@+id/avatar"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/avatar"
        android:layout_width="264dp"
        android:layout_height="0dp"
        android:layout_marginEnd="158dp"
        app:cardBackgroundColor="@color/card_bg_color"
        app:cardCornerRadius="@dimen/rec_music_item_avatar_radius"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_rec2_daily_play_mask"
        app:layout_constraintBottom_toBottomOf="@+id/btn_music_play"
        app:layout_constraintEnd_toEndOf="@+id/btn_music_play"
        app:layout_constraintStart_toStartOf="@+id/btn_music_play"
        app:layout_constraintTop_toTopOf="@+id/btn_music_play"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_rec2_daily_play_mask2"
        app:layout_constraintBottom_toBottomOf="@+id/btn_music_play"
        app:layout_constraintEnd_toEndOf="@+id/btn_music_play"
        app:layout_constraintStart_toStartOf="@+id/btn_music_play"
        app:layout_constraintTop_toTopOf="@+id/btn_music_play"/>
    <com.wanos.media.juyihall.view.PlayableLayout
        android:layout_gravity="center"
        android:id="@+id/btn_music_play"
        android:background="@drawable/ic_rec2_daily_play_bg"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="83dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/iv_music_play"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/group_card_pause"/>
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/pb_music_play"
            android:visibility="gone"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminate="true"
            android:alpha="0.9"
            android:indeterminateTint="#ffffff"/>
    </com.wanos.media.juyihall.view.PlayableLayout>
    <TextView
        android:textSize="48sp"
        android:textColor="@color/white"
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="65dp"
        android:text="@string/rec2_header_daily_title"
        android:layout_marginStart="80dp"
        app:layout_constraintStart_toEndOf="@+id/btn_music_play"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="80dp"
        android:layout_marginVertical="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/avatar"
        app:layout_constraintStart_toEndOf="@+id/btn_music_play"
        app:layout_constraintTop_toBottomOf="@+id/title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
