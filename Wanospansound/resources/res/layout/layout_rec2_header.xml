<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="470dp">
    <com.wanos.media.juyihall.view.DailyMusicView
        android:id="@+id/daily_view"
        android:layout_width="1262dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toStartOf="@+id/banner_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/banner_layout"
        android:layout_width="610dp"
        android:layout_height="334dp"
        android:layout_marginStart="42dp"
        app:cardBackgroundColor="@color/transparent"
        app:cardCornerRadius="@dimen/rec_music_item_top_radius"
        app:cardElevation="0dp"
        app:contentPadding="0dp"
        app:layout_constraintEnd_toStartOf="@+id/tv_recent"
        app:layout_constraintStart_toEndOf="@+id/daily_view"
        app:layout_constraintTop_toTopOf="parent">
        <com.wanos.media.ui.widget.banner.Banner
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollIndicators="bottom"
            app:banner_auto_loop="true"
            app:banner_indicator_gravity="center"
            app:banner_indicator_height="@dimen/banner_indicator_height"
            app:banner_indicator_marginBottom="@dimen/banner_indicator_magin_bottom"
            app:banner_indicator_normal_color="@color/banner_indicator_normal_color"
            app:banner_indicator_normal_width="@dimen/banner_indicator_normal_width"
            app:banner_indicator_radius="@dimen/banner_indicator_radius"
            app:banner_indicator_selected_color="@color/white"
            app:banner_indicator_selected_width="@dimen/banner_indicator_selected_width"
            app:banner_indicator_space="12dp"
            app:banner_infinite_loop="true"
            app:banner_orientation="horizontal"
            app:banner_radius="@dimen/rec_music_item_top_radius"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="36sp"
        android:textColor="@color/text_color"
        android:gravity="center"
        android:id="@+id/tv_collect"
        android:background="@drawable/bg_rec2_header_recent_juyiting"
        android:layout_width="284dp"
        android:layout_height="96dp"
        android:layout_marginTop="40dp"
        android:text="@string/rec2_header_collect"
        android:paddingHorizontal="34dp"
        app:drawableStartCompat="@drawable/ic_rec2_header_collect"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_recent"
        app:layout_constraintStart_toStartOf="@+id/banner_layout"
        app:layout_constraintTop_toBottomOf="@+id/banner_layout"/>
    <TextView
        android:textSize="36sp"
        android:textColor="@color/text_color"
        android:gravity="center"
        android:id="@+id/tv_recent"
        android:background="@drawable/bg_rec2_header_recent_juyiting"
        android:layout_width="284dp"
        android:layout_height="96dp"
        android:layout_marginTop="40dp"
        android:text="@string/rec2_header_recent"
        android:layout_marginStart="42dp"
        android:paddingHorizontal="34dp"
        app:drawableStartCompat="@drawable/ic_rec2_header_recent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/banner_layout"
        app:layout_constraintStart_toEndOf="@+id/tv_collect"
        app:layout_constraintTop_toBottomOf="@+id/banner_layout"/>
</androidx.constraintlayout.widget.ConstraintLayout>
