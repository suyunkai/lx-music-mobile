<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/relax_setting_cover_image_width"
    android:layout_height="@dimen/relax_setting_cover_image_height"
    app:cardBackgroundColor="#00000000"
    app:cardCornerRadius="@dimen/relax_radius"
    app:cardElevation="0px"
    app:cardUseCompatPadding="false">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/im_space_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <com.wanos.media.widget.WanosTextView
        android:textSize="@dimen/relax_main_text_size"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:layout_gravity="end"
        android:id="@+id/tv_space_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/relax_setting_item_icon_space"
        android:maxLines="1"
        android:layout_marginEnd="@dimen/relax_setting_item_icon_space"
        app:layout_constraintRight_toRightOf="@+id/im_space_bg"
        app:layout_constraintTop_toTopOf="@+id/im_space_bg"/>
    <View
        android:id="@+id/im_space_conver_bg"
        android:background="@color/zero_setting_mask_color"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_download_flag"
        android:layout_width="@dimen/relax_dialog_loading_min_size"
        android:layout_height="@dimen/relax_dialog_loading_min_size"
        android:layout_marginTop="@dimen/relax_setting_item_icon_space"
        android:src="@drawable/ic_download_tag"
        android:layout_marginStart="@dimen/relax_setting_item_icon_space"/>
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="@dimen/relax_dialog_loading_min_size"
        android:layout_height="@dimen/relax_dialog_loading_min_size"
        android:layout_marginTop="@dimen/relax_setting_item_icon_space"
        android:layout_marginStart="@dimen/relax_setting_item_icon_space"
        android:indeterminateTint="@color/white"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="center"
        android:id="@+id/im_check_btn"
        android:layout_width="@dimen/relax_setting_check_box_size"
        android:layout_height="@dimen/relax_setting_check_box_size"
        android:src="@drawable/ctrl_checkbox"/>
</androidx.cardview.widget.CardView>
