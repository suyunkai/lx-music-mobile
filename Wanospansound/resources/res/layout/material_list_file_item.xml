<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/layout_file_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/material_list_file_item_margin_b"
        android:paddingStart="@dimen/material_list_file_item_padding_s_e">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/material_list_item_h"
            android:layout_marginBottom="@dimen/material_list_file_item_margin_b"
            android:paddingEnd="@dimen/material_list_file_item_padding_s_e">
            <ImageView
                android:id="@+id/material_file_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_material_file_item"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/material_list_file_item_name_text_size"
                android:textColor="#ffffff"
                android:ellipsize="end"
                android:id="@+id/material_file_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/material_list_file_item_title_margin_l"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/material_file_icon"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/material_file_arrows"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_file_item_right_arrows"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@+id/material_file_pb"
                android:visibility="gone"
                android:layout_width="80dp"
                android:layout_height="50dp"
                android:indeterminate="true"
                android:alpha="0.9"
                android:indeterminateTint="#ffffff"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/expansion_recycler_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"/>
    </LinearLayout>
</FrameLayout>
