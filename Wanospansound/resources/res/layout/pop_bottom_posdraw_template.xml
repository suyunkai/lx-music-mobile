<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="800dp">
    <View
        android:background="@drawable/pop_bottom_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:background="@color/editing_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/view_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="82dp"
            android:layout_marginTop="13dp">
            <TextView
                android:textSize="28dp"
                android:textColor="@color/color_fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="速度"/>
            <SeekBar
                android:layout_gravity="center"
                android:id="@+id/seekbar_speed"
                android:background="@null"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"
                android:layout_width="1648dp"
                android:layout_height="40dp"
                android:max="20"
                android:progress="0"
                android:progressDrawable="@drawable/progress_seekbar_2"
                android:thumb="@drawable/seek_thumb2"
                android:thumbOffset="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:min="5"
                android:layout_marginHorizontal="24dp"
                android:paddingHorizontal="0dp"/>
            <TextView
                android:textSize="40sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_speed"
                android:layout_width="150dp"
                android:layout_height="96dp"
                android:layout_marginLeft="20dp"
                android:text=" 1.0x"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="188dp"
        android:layout_height="92dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/dialog_close"
        android:layout_marginStart="80dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="48sp"
        android:textColor="#ffffff"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="66dp"
        android:text="轨迹模版"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:padding="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/iv_draw_help"
        android:cropToPadding="true"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintLeft_toRightOf="@+id/tv_title"
        app:layout_constraintTop_toTopOf="@+id/tv_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
