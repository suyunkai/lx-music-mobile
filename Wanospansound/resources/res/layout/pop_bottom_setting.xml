<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_win"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialog_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/pop_bottom_height"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <View
            android:background="@drawable/pop_bottom_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <View
            android:background="@color/editing_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_beat_switch"
                android:background="@drawable/setting_item_bg"
                android:layout_width="360dp"
                android:layout_height="268dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                <FrameLayout
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp">
                    <ImageView
                        android:id="@+id/swich_beat"
                        android:background="@drawable/ic_creator_setting_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>
                <TextView
                    android:textSize="34sp"
                    android:textColor="#99ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:text="@string/show_jp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_speed"
                android:background="@drawable/setting_item_bg"
                android:layout_width="360dp"
                android:layout_height="268dp"
                android:layout_marginLeft="68dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp">
                    <com.wanos.careditproject.view.widget.LongClickImageView
                        android:id="@+id/btn_speed_minus"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_speed_minus"/>
                    <TextView
                        android:textSize="60sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/tv_beat_speed"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:text="120"/>
                    <com.wanos.careditproject.view.widget.LongClickImageView
                        android:id="@+id/btn_speed_plus"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_speed_plus"/>
                </LinearLayout>
                <TextView
                    android:textSize="34sp"
                    android:textColor="#99ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:text="@string/beat_speed"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_beat_number"
                android:background="@drawable/setting_item_bg"
                android:layout_width="360dp"
                android:layout_height="268dp"
                android:layout_marginLeft="68dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:textSize="60sp"
                    android:textColor="@color/white"
                    android:id="@+id/tv_beat_number"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:text="4/4"/>
                <TextView
                    android:textSize="34sp"
                    android:textColor="#99ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:text="@string/beat_num"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_input_devices"
                android:background="@drawable/setting_item_bg"
                android:visibility="gone"
                android:layout_width="360dp"
                android:layout_height="268dp"
                android:layout_marginLeft="68dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    android:paddingLeft="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/input_devices"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    android:gravity="center_vertical"
                    android:id="@+id/tv_input_devices"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="XXX的麦克风"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_midi_devices"
                android:background="@drawable/setting_item_bg"
                android:layout_width="360dp"
                android:layout_height="268dp"
                android:layout_marginLeft="68dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:textSize="60sp"
                    android:textColor="@color/white"
                    android:id="@+id/tv_midi_device_name"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:text="@string/midi_devices_none"/>
                <TextView
                    android:textSize="34sp"
                    android:textColor="#99ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:text="@string/midi_devices"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="188dp"
            android:layout_height="92dp"
            android:layout_marginTop="50dp"
            android:src="@drawable/dialog_close"
            android:layout_marginStart="80dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="48sp"
            android:textColor="#99ffffff"
            android:id="@+id/tv_title_db"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="66dp"
            android:text="设置"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
