<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/radio_group"
    android:background="@drawable/bg_pop_midi_select_instrument"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="21dp"
    android:paddingVertical="10dp">
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/layout_instrument1"
        android:background="@drawable/selector_pop_midi_edit_quantization"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginVertical="10dp">
        <ImageView
            android:id="@+id/iv_instrument1"
            android:padding="10dp"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_midi_pop_select_instrument_play"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/piano"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/layout_instrument2"
        android:background="@drawable/selector_pop_midi_edit_quantization"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginVertical="10dp">
        <ImageView
            android:id="@+id/iv_instrument2"
            android:padding="10dp"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_midi_pop_select_instrument_play"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guitar"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/layout_instrument3"
        android:background="@drawable/selector_pop_midi_edit_quantization"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginVertical="10dp">
        <ImageView
            android:id="@+id/iv_instrument3"
            android:padding="10dp"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_midi_pop_select_instrument_play"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bass"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/layout_instrument4"
        android:background="@drawable/selector_pop_midi_edit_quantization"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginVertical="10dp">
        <ImageView
            android:id="@+id/iv_instrument4"
            android:padding="10dp"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_midi_pop_select_instrument_play"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drums"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</LinearLayout>
