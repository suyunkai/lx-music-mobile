<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/creator_more_dialog_bg"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:contentPadding="0dp">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp">
        <Button
            android:textSize="34sp"
            android:textColor="@color/text_color"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/btn_privacy"
            android:background="@drawable/project_more_item_bg_selector"
            android:layout_width="288dp"
            android:layout_height="80dp"/>
        <Button
            android:textSize="34sp"
            android:textColor="@color/text_color"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/btn_delete"
            android:background="@drawable/project_more_item_bg_selector"
            android:layout_width="288dp"
            android:layout_height="80dp"
            android:text="@string/project_delete"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
