<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:id="@+id/music_source_item"
    android:layout_width="match_parent"
    android:layout_height="@dimen/source_list_item_height"
    android:paddingStart="@dimen/source_popup_item_padding_s"
    android:paddingEnd="@dimen/source_popup_item_padding_s">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon_image_view"
        android:layout_width="@dimen/source_icon_size"
        android:layout_height="@dimen/source_icon_size"
        android:src="@drawable/ic_default_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/source_title_text_size"
        android:textColor="@color/source_text_color"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/name_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="@dimen/source_name_text_padding_start"
        android:paddingEnd="@dimen/source_name_text_padding_end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/check_image_view"
        app:layout_constraintStart_toEndOf="@+id/icon_image_view"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/check_image_view"
        android:visibility="gone"
        android:layout_width="@dimen/source_check_icon_size"
        android:layout_height="@dimen/source_check_icon_size"
        android:src="@drawable/ic_check"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/name_text_view"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
