<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/fl_number_picker"
        android:background="@drawable/number_picker_bg"
        android:layout_width="@dimen/relax_control_time_size"
        android:layout_height="@dimen/relax_control_time_size">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.wanos.media.widget.WanosTextView
                android:textSize="@dimen/relax_control_time_hint_text_size"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:id="@+id/tv_focus_1"
                android:layout_width="0px"
                android:layout_height="match_parent"
                android:text="@string/ds_str"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/relax_control_time_hint_text_merge_h"/>
            <com.wanos.media.widget.WanosTextView
                android:textSize="@dimen/relax_control_time_hint_text_size"
                android:textColor="#ffffff"
                android:gravity="end|center_vertical"
                android:id="@+id/tv_focus_2"
                android:layout_width="0px"
                android:layout_height="match_parent"
                android:text="@string/min_fz_str"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/relax_control_time_hint_text_merge_h"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <com.wanos.media.widget.WanosTimePicker
            android:id="@+id/number_picker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:wtp_ItemPaddingHorizental="0dp"
            app:wtp_ItemPaddingVertical="@dimen/relax_control_time_picker_padding_h"
            app:wtp_TextColorNormal="#99ffffff"
            app:wtp_TextColorSelected="#ffffff"
            app:wtp_TextSizeNormal="@dimen/relax_control_time_picker_normal_text_size"
            app:wtp_TextSizeSelected="@dimen/relax_control_time_picker_select_text_size"
            app:wtp_WrapSelectorWheel="true"/>
    </FrameLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:layout_gravity="center_horizontal"
        android:id="@+id/rv_ming_xiang"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/relax_control_time_ming_xiang_height"/>
</FrameLayout>
